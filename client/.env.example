# Frontend env. The app needs no frontend env vars: the hyperreal officer is
# powered by Tavus via the FastAPI backend (its key lives in the backend's
# ../.env), and the waitlist posts to the backend's /api/waitlist.

# Optional: override the embed endpoint the client calls. Defaults to
# /api/liveavatar/embed, which the Vite dev server proxies to the backend.
# VITE_LIVEAVATAR_EMBED_URL=/api/liveavatar/embed
