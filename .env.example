AVATAR_API_KEY=your-api-key

# Officer face. List options with `GET /api/replicas` and paste a replica_id here.
# Defaults to a built-in face if unset.
# AVATAR_REPLICA_ID=rfb0463909e3

# Provider-hosted LLM that drives the persona (optional override; sensible default).
# AVATAR_LLM_MODEL=

# Pre-provisioned persona ids. Run `python backend/scripts/provision.py` once and
# paste the printed ids here so cold starts skip provisioning.
# PERSONA_B1B2_ID=
# PERSONA_F1_ID=
# PERSONA_H1B_ID=
# PERSONA_J1_ID=
# PERSONA_N400_ID=

# Default interview language; full name, e.g. english / spanish.
# DEFAULT_LANGUAGE=english

# Visible interview length in seconds (the client countdown). Lower this to
# conserve minutes. Default 240 (4 minutes).
# INTERVIEW_DURATION_SECONDS=240

# Knowledge base: public URL to the USCIS 100 civics questions. Defaults to the
# official USCIS PDF; set empty to disable civics grounding.
# CIVICS_DOCUMENT_URL=https://www.uscis.gov/sites/default/files/document/questions-and-answers/100q.pdf

# Public HTTPS base URL of this server (e.g. a tunnel URL) so the provider can POST
# webhooks to <base>/api/webhook. Leave unset to rely on polling for reports.
# PUBLIC_BASE_URL=https://your-public-url.example.com

# Waitlist storage. With these set, /api/waitlist signups are saved to a `waitlist`
# table in your database (durable, dedupes on email); without them they fall back
# to a local JSONL file (WAITLIST_FILE, default waitlist.jsonl). Use the service
# key (server-side only). See the README "Waitlist" section for the one table to create.
# DB_URL=https://your-database-host.example.com
# DB_SERVICE_KEY=your-service-key
# WAITLIST_FILE=waitlist.jsonl

# Set a secret to enable the admin view of signups (GET /api/waitlist with the
# X-Admin-Token header). Unset = the endpoint returns 404.
# ADMIN_TOKEN=a-long-random-secret
